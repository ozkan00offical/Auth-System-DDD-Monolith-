generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

model User {
  id         String   @id @default(cuid())
  name       String
  email      String   @unique
  tell       String   @unique
  password   String

  role       Role     @default(USER)

  active     Boolean   @default(true)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
